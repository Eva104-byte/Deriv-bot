# ─────────────────────────────────────────────────────────────
#  Deriv Differs Bot — Environment Variables
#  Copy this file to .env for local testing (never commit .env)
#  On Railway: paste these into the "Variables" tab instead
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────
DERIV_API_TOKEN=u3ICO3zcGqmGBHv

# ── Starting market (optional) ────────────────────────────────
MARKET=1HZ50V

# ── Digit Differs Bot ─────────────────────────────────────────
DIFFERS_ENABLED=true
DIFFERS_STAKE=1.00
DIFFERS_DURATION=1
DIFFERS_MODE=auto
# DIFFERS_MANUAL_DIGIT=3      # only needed if DIFFERS_MODE=manual
DIFFERS_TARGET_PROFIT=10.00
DIFFERS_STOP_LOSS=5.00

# ── Even / Odd Bot ────────────────────────────────────────────
EO_ENABLED=false
EO_STAKE=1.00
EO_DURATION=1
EO_TARGET_PROFIT=10.00
EO_STOP_LOSS=5.00

# ── Auto Digit Selector ───────────────────────────────────────
ADS_ENABLED=true
ADS_TICK_SAMPLE=1000
ADS_THRESHOLD=8.5
ADS_SCAN_INTERVAL=300
# ADS_MARKETS=1HZ10V,1HZ25V,1HZ50V,1HZ100V   # comma-separated, overrides default list

# ── Deriv App ID (leave default unless you registered your own) ─
# DERIV_APP_ID=1089
